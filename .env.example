# Public project URL (safe for browser exposure)
NEXT_PUBLIC_SUPABASE_URL=

# Server-only. Never expose this value to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Protects /api/cron/sync. Vercel Cron sends Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# Optional extra connectors. The free production connectors below are enabled automatically:
# muqawil-projects, ncp-ppp, swpc-future-projects, pif-opportunities,
# furas-investment, public-procurement-pages, plus free Balady/National Open Data catalog sync.
# Leave empty unless adding an optional connector.
DATA_SOURCES=

# Legacy single-source option, kept for backwards compatibility.
DATA_SOURCE=

# Public Muqawil project pages to ingest during cron sync (1-200).
MUQAWIL_PROJECTS_MAX_PAGES=5

# Smaller live fallback used when Supabase is absent or contains zero tenders (1-10).
MUQAWIL_LIVE_MAX_PAGES=3

# Mock data is disabled by default. Enable only for local development/testing.
ALLOW_MOCK_DATA=false

# Optional Etimad integration only. NOT required for the free-data-first deployment.
# The application continues to use free public sources when these values are empty.
ETIMAD_OPEN_DATA_BASE_URL=
ETIMAD_OPEN_DATA_GROUP_ID=
ETIMAD_OPEN_DATA_FILE_FORMAT=2

# Legacy direct endpoint override. Optional and kept for backwards compatibility.
ETIMAD_PUBLIC_API_URL=
